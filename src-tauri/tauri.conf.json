{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ExcelCheckTool",
  "mainBinaryName": "ExcelCheckTool",
  "version": "0.3.1",
  "identifier": "com.ray.excel-check-tool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "表格核对工具",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 720,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false
    },
    "resources": {
      "../check_templates.json": "check_templates.json",
      "../position_aliases.json": "position_aliases.json",
      "../position_rules.json": "position_rules.json",
      "../Nothing_You_Could_Do": "Nothing_You_Could_Do"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaW5pIHB1YmxpYyBrZXk6IEQyQUNGRDc1N0YwNjU5MDkKUldRSldRWi9kZjJzMG8yM1hlRXFMQzV4Vi92UHhWNnhNUHNOYTIzbTMwN2xFSlVSbFg3L1RsTVIK",
      "endpoints": [
        "https://github.com/bollus/checker/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
